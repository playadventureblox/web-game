# Production Environment Variables for Frontend
# These variables will be set in Cloudflare Pages Dashboard
# DO NOT commit actual values - this is just a template

# API URL - Update with your actual API domain after backend deployment
# Examples:
#   - Railway: https://your-app.up.railway.app/api/v1
#   - Render: https://your-app.onrender.com/api/v1
#   - Custom domain: https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=https://your-backend-url-here.com/api/v1

# Optional: Analytics tracking ID
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Optional: Feature flags
# NEXT_PUBLIC_ENABLE_CHAT=true
# NEXT_PUBLIC_ENABLE_GROUPS=true
